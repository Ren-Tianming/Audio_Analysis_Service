AUDIO_APP_NAME=Audio_Analysis_System
AUDIO_ENVIRONMENT=development
AUDIO_LOG_LEVEL=INFO
AUDIO_DATABASE_URL=mysql+pymysql://audio_user:audio_password@localhost:3306/audio_analysis?charset=utf8mb4
AUDIO_REDIS_URL=redis://localhost:6379/0
AUDIO_JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
AUDIO_JWT_EXPIRE_MINUTES=60
AUDIO_REFRESH_TOKEN_EXPIRE_DAYS=30
AUDIO_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
AUDIO_UPLOAD_DIR=storage/uploads
AUDIO_RATE_LIMIT_REQUESTS=60
AUDIO_AUTH_RATE_LIMIT_REQUESTS=10
AUDIO_RATE_LIMIT_WINDOW_SECONDS=60
AUDIO_AUTO_CREATE_TABLES=false
